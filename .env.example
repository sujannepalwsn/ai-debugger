# AI Debugger Configuration
# Set these in your environment to avoid entering them in the UI

# Gemini API Key for AI Analysis (Optional, fallback to Rule Engine if missing)
GEMINI_API_KEY=

# GitHub Integration for Self-Healing PRs
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Supabase Integration for Real Error Logs
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ERROR_TABLE=error_logs

# Autonomous PR Creation (true/false)
AUTO_PR=false
